# === CheapHouse Japan Pipeline Configuration ===

# Supabase (REQUIRED for database operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Database (direct Postgres — used by ingestion scripts)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# LLM Provider: "ollama" (free, local) or "openai" (paid, cloud)
LLM_PROVIDER=ollama

# Ollama (local) — make sure `ollama serve` is running
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# OpenAI (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Pipeline limits (auto_pipeline.py uses these if set)
# ENRICH_LIMIT=500

# Rate limiting
SCRAPE_DELAY_SECONDS=2
LLM_BATCH_SIZE=10

# === European Scraping ===
# Idealista API (register at developers.idealista.com)
# IDEALISTA_API_KEY=your-key-here
# IDEALISTA_API_SECRET=your-secret-here
EUROPE_SCRAPE_DELAY_SECONDS=3
EUROPE_LLM_BATCH_SIZE=10
